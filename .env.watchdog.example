# Watchdog Configuration
# Copy this file to .env.watchdog and edit with your values

# Telegram Bot
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_HERE"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID_HERE"

# Target server to monitor (the OTHER server)
# Same network: use IP, e.g. "192.168.1.100"
# Different network: use domain, e.g. "chatech.site"
TARGET_HOST="chatech.site"
TARGET_PORT="443"
TARGET_NAME="Server Rumah"

# This server's identity
THIS_SERVER="Server Kantor"

# How many consecutive failures before alerting
FAIL_THRESHOLD=3

# Use HTTPS? (yes/no) — set "yes" if using Cloudflare domain
USE_HTTPS="yes"
